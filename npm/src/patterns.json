      "weight": 50,
      "category": "explicit_attack",
      "description": "Explicit mention of prompt injection"
    },
    {
      "id": "hypothetical_attack",
      "pattern": "(?i)(hypothetically|in\\s+a\\s+fictional\\s+world|for\\s+a\\s+story|imagine\\s+if|let's\\s+say|suppose|what\\s+if)\\s+.{0,50}(ignore|bypass|reveal|override|jailbreak|system\\s+prompt|no\\s+restrictions?|unrestricted)",
      "weight": 25,
      "category": "obfuscated_attack",
      "description": "Hypothetical framing to bypass restrictions"
    },
    {
      "id": "token_manipulation",
      "pattern": "(?i)(</?(system|human|assistant|user|ai|prompt|instruction)>|\\[INST\\]|\\[/INST\\]|<s>|</s>|<<SYS>>|<</SYS>>|\\|im_start\\||\\|im_end\\||<\\|endoftext\\|>)",
      "weight": 45,
      "category": "token_injection",
      "description": "Attempts to inject special tokens"
    },
    {
      "id": "repeat_attack",
      "pattern": "(?i)(repeat\\s+(after\\s+me|the\\s+following|this|everything|verbatim)|echo\\s+(back\\s+)?(this|the\\s+following)|copy\\s+and\\s+paste\\s+(the\\s+following|this|your\\s+instructions?))",
      "weight": 20,
      "category": "data_exfiltration",
      "description": "Repetition-based data extraction"
    },
    {
      "id": "translate_attack",
      "pattern": "(?i)translate\\s+(the\\s+)?(following|this|your|system|above|previous)\\s+(to|into)\\s+\\w+\\s*:?\\s*(system\\s+prompt|your\\s+instructions?|your\\s+rules?)",
      "weight": 30,
      "category": "data_exfiltration",
      "description": "Translation-based prompt extraction"
    },
    {
      "id": "base64_encoded",
      "pattern": "(?i)(decode|base64|hex|rot13|caesar\\s+cipher|encoded?|obfuscat)\\s+.{0,30}(instruction|command|override|bypass|ignore|system)",
      "weight": 35,
      "category": "obfuscated_attack",
      "description": "Encoded/obfuscated attack attempt"
    },
    {
      "id": "new_instructions",
      "pattern": "(?i)(new\\s+(instructions?|rules?|guidelines?|directives?)|updated\\s+(instructions?|rules?|guidelines?)|from\\s+now\\s+on|starting\\s+now|henceforth)\\s*[:,]?\\s*(you\\s+(will|must|shall|should|are\\s+to)|do\\s+not|never|always|stop)",
      "weight": 30,
      "category": "instruction_override",
      "description": "Attempts to set new persistent instructions"
    },
    {
      "id": "sudo_mode",
      "pattern": "(?i)\\b(sudo|root\\s+access|admin\\s+(mode|access|override)|master\\s+(key|override|mode)|super\\s+user|privileged\\s+mode|maintenance\\s+mode)\\b",
      "weight": 30,
      "category": "privilege_escalation",
      "description": "Privilege escalation attempt"
    },
    {
      "id": "training_data",
      "pattern": "(?i)(what\\s+(were\\s+you\\s+trained|training\\s+data|data\\s+used)|show\\s+(me\\s+)?(your\\s+)?(training\\s+data|dataset)|tell\\s+me\\s+(about\\s+)?(your\\s+)?(training|fine.?tuning))",
      "weight": 15,
      "category": "data_exfiltration",
      "description": "Training data extraction attempt"
    }
  ],
