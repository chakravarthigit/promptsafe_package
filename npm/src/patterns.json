      "weight": 45,
      "category": "jailbreak",
      "description": "Known jailbreak attempt patterns"
    },
    {
      "id": "system_override",
      "pattern": "(?i)\\b(system\\s+override|override\\s+system|bypass\\s+(restrictions?|filters?|safety|guidelines?|rules?|policies?)|disable\\s+(safety|filters?|restrictions?|guardrails?)|remove\\s+(restrictions?|filters?|safety|limits?)|unlock\\s+(mode|capabilities?|restrictions?))\\b",
