      "weight": 35,
      "category": "instruction_override",
      "description": "Attempts to override previous instructions"
    },
    {
      "id": "forget_instructions",
      "pattern": "(?i)(forget|disregard|override|bypass|skip|ignore|delete|remove)\\s+(all\\s+)?(your\\s+)?(previous|prior|system|original|initial)\\s+(instructions?|prompts?|rules?|context|training|settings?|constraints?)",
      "weight": 35,
      "category": "instruction_override",
      "description": "Instructs model to forget system context"
